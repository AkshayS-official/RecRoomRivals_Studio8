    m_PersistentCalls:
      m_Calls: []
  m_text: "1.  Spawn at center court \u2014 free to roam\n\n2.  Walk up to the Coach
    NPC\n\n3.  A button appears \u2014 POKE it!\n    (or press  E  on keyboard)\n\n4. 
    Countdown:  3 \u2026 2 \u2026 1 \u2026 GO!\n\n5.  Teleport to a shooting position\n\n6. 
    Hold  T  to enter AIM mode\n    A trajectory arc shows the ball path\n    Hold
    longer = more throw force\n\n7.  Press  G  to THROW along the arc!\n    Release
    T before G to cancel aim\n\n8.  Aim for YOUR hoop \u2014 score points!\n\n9. 
    Bot shoots at the same time\n\n10. Positions change every round\n\n11. 2-min
    timer \u2014 most baskets WINS!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
